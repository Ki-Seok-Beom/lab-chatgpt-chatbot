# Auto-normalize text files and preserve binary files across platforms
* text=auto

# Force LF line endings for source/config files
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ipynb text eol=lf
*.csv text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
*.dockerfile text eol=lf

# Treat binary files as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.xz binary
